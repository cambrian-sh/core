# Operating system / binary / build files
*.exe
*.db
*.log
*.pyc
*.pptx
*.test

# Build / benchmark / test artifacts — scoped, NOT blanket extension bans
# (the old *.txt/*.csv/*.html/*.ts bans silently dropped legitimate source/fixtures). ADR-0057.
benchmarks/

# Go workspace — local multi-module dev (lives in parent dir); never committed.
go.work
go.work.sum

# Generated and workspace directories
.agents/
.tmp/
.test-results/
.claude/
.omo/
.opencode/
graphify-out/
plans/
.wiki/
.sisyphus/
deliverables/
venv/


# Secrets — never commit (.env.example is the committed template)
.env
.env.*
!.env.example

# Operator/user config — holds real endpoints, paths & secrets. Ship the template
# (config.example.json) instead; users copy it to config.json. ADR-0057.
configs/config.json
configs/config.local.json
configs/config.dev.json
# Per-machine tuning overrides (curated power-user starter lives in tuning.json,
# committed; tune in tuning.local.json instead). Config split per `.omo/plans/config-split.md`.
configs/tuning.local.json
# Per-machine MCP server definitions (template lives in mcp.json.example, committed;
# operators copy to mcp.json and add servers). Config split per `.omo/plans/config-split.md`.
configs/mcp.json
# Embedder model config (template lives in embedder.json.example, committed; operators
# copy to embedder.json). Per-machine override: embedder.local.json. Config split per ADR-0024.
configs/embedder.json
configs/embedder.local.json
# LLM provider list (template lives in providers.json.example, committed; operators copy
# to providers.json). Per-machine override: providers.local.json. Config split per ADR-0024.
configs/providers.json
configs/providers.local.json

# Project metadata and lock files
skills-lock.json
.generate_presentation.js

# Graphify and related files
.graphifyignore
.graphify*
.gf_python

