# Copy to .env and fill in real values. The .env file is gitignored.
# Each key here is referenced from configs/config.json via "api_key_env",
# or as a CAMBRIAN_* override consumed by the koanf env layer.

# OpenCode Zen (OpenAI-compatible) API key — used by models[].provider "openai".
OPENCODE_API_KEY=

# Google Gemini (via OpenAI-compatible endpoint) API key. Get one at
# https://aistudio.google.com/apikey. Used by the "gemini-flash" generator;
# the `memory` role in config.json points at it for the chunk-fill back-fill.
# Free tier limits: 15 RPM, 1M TPM, 1500 RPD (gemini-2.0-flash).
GEMINI_API_KEY=

# Example: override the Postgres password without editing config.json.
# CAMBRIAN_DATABASE__PASSWORD=
