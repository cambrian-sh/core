{
  "_comment": "Copy to mcp.json (gitignored) and edit. Add as many `servers` entries as you need. Auth secrets come from env vars (auth.token_env); never inline them. See ADR-0043 for per-tool policy schema (pricing/dangerous/data_write_kinds). Adjust the `endpoint` path for your OS — the example below uses a Unix-style relative path; on Windows, use .exe suffix. WARNING: an empty `{\"mcp\": {}}` here will silently wipe any `mcp` block in config.json because Koanf merges per-key. Don't create mcp.json if you don't use MCP.",

  "mcp": {
    "default_session_budget": 0,
    "call_timeout_ms": 60000,
    "servers": [
      {
        "id": "filesystem",
        "transport": "stdio",
        "endpoint": "./bin/reference-fs-mcp",
        "auth": {"type": "none"},
        "tools": [
          {"name": "read_file",     "dangerous": false},
          {"name": "list_directory","dangerous": false}
        ]
      }
    ]
  }
}
